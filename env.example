# ── Gov Tender Portal — Production Environment Variables ──────────────────────
# Copy to .env.  NEVER commit .env to version control.
# In AWS: store all secrets in AWS Secrets Manager, not in this file.

# ── Flask ─────────────────────────────────────────────────────────────────────
FLASK_ENV=production
SECRET_KEY=CHANGE_ME_GENERATE_RANDOM_32_BYTE_HEX
JWT_SECRET_KEY=CHANGE_ME_ANOTHER_RANDOM_SECRET

# ── Amazon RDS PostgreSQL ─────────────────────────────────────────────────────
# Endpoint from RDS console (resolved inside private subnet via VPC DNS)
DATABASE_URL=postgresql://tender_admin:StrongPassword@tender-prod.xxxxxxxx.ap-south-1.rds.amazonaws.com:5432/tender_prod

# ── Bid Encryption ────────────────────────────────────────────────────────────
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
BID_ENCRYPTION_KEY=CHANGE_ME_FERNET_KEY_HERE

# ── Amazon S3 ─────────────────────────────────────────────────────────────────
USE_S3=true
AWS_S3_BUCKET=tender-uploads-prod-<account_id>
AWS_S3_REGION=ap-south-1
# Do NOT set AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY in production.
# Attach an IAM role to the EC2 instance instead (see deployment guide).

# ── Amazon SES ────────────────────────────────────────────────────────────────
USE_SES=true
AWS_SES_REGION=ap-south-1
MAIL_DEFAULT_SENDER=noreply@tender.gov.in   # Must be SES-verified identity

# ── Amazon SNS ────────────────────────────────────────────────────────────────
AWS_SNS_REGION=ap-south-1
SNS_TENDER_PUBLISHED_TOPIC_ARN=arn:aws:sns:ap-south-1:<account_id>:tender-published
SNS_BID_AWARDED_TOPIC_ARN=arn:aws:sns:ap-south-1:<account_id>:bid-awarded

# ── Amazon Textract / Comprehend ──────────────────────────────────────────────
USE_TEXTRACT=true

# ── Amazon Cognito ────────────────────────────────────────────────────────────
# Optional — enable if you want Cognito to manage vendor authentication
USE_COGNITO=false
COGNITO_USER_POOL_ID=ap-south-1_xxxxxxxxx
COGNITO_APP_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
COGNITO_REGION=ap-south-1
COGNITO_DOMAIN=tender-portal.auth.ap-south-1.amazoncognito.com

# ── App behind API Gateway ────────────────────────────────────────────────────
BEHIND_API_GATEWAY=false

# ── Redis (for rate limiting + Celery broker) ─────────────────────────────────
# Use ElastiCache Redis endpoint (private subnet, accessible via VPC)
REDIS_URL=redis://tender-cache.xxxxxx.0001.apse1.cache.amazonaws.com:6379/0

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
